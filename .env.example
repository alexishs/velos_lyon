# UID et GID de l'utilisateur hôte pour les conteneurs Airflow
# Obtenir les valeurs avec : echo "$(id -u):$(id -g)"
AIRFLOW_UID=1000

# Clé API JCDecaux (https://developer.jcdecaux.com)
JCDECAUX_API_KEY=

# GID du groupe docker de l'hôte (pour que les conteneurs Airflow puissent invoquer
# `docker exec` via le socket Docker monté). Obtenir la valeur avec :
# getent group docker | cut -d: -f3
DOCKER_GID=988
